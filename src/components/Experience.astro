---
import { experience } from "../data/experience";
---

<section
	id="experience"
	class="relative border-b border-border/80"
	aria-labelledby="experience-heading"
>
	<div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
		<div>
			<h2
				id="experience-heading"
				class="font-semibold text-4xl tracking-tight text-ink md:text-5xl"
			>
				Experience highlights
			</h2>
			<p class="mt-3 max-w-2xl text-muted">
				Selected roles and recent highlights.
			</p>
		</div>

		<ul class="mt-10 space-y-6">
			{
				experience.map((job) => (
					<li class="rounded-xl border border-border bg-surface-muted/30 p-5 md:p-6">
						<div class="flex flex-col gap-1 md:flex-row md:items-baseline md:justify-between">
							<div>
								<h3 class="text-lg font-semibold text-ink">{job.title}</h3>
								<p class="text-muted">{job.organization}</p>
							</div>
							<p class="text-sm font-medium text-accent/90 md:text-right">{job.dates}</p>
						</div>
						<ul class="mt-4 list-disc space-y-2 pl-5 text-sm leading-relaxed text-ink/90">
							<li>{job.highlights[0]}</li>
							<li>{job.highlights[1]}</li>
						</ul>
					</li>
				))
			}
		</ul>
	</div>
</section>
