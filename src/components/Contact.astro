---
import { siteConfig } from "../site.config";
import { publicUrl } from "../utils/publicUrl";

const phoneDigits = siteConfig.phone?.replace(/\D/g, "") ?? "";
const phoneHref =
	phoneDigits.length === 10
		? `tel:+1${phoneDigits}`
		: phoneDigits.length > 0
			? `tel:+${phoneDigits}`
			: "";
---

<section id="contact" class="relative" aria-labelledby="contact-heading">
	<div class="mx-auto max-w-6xl px-4 py-16 md:py-20">
		<div class="grid gap-10 md:grid-cols-[minmax(0,220px)_1fr] md:items-center lg:grid-cols-[minmax(0,260px)_1fr]">
			<div class="mx-auto w-full max-w-[220px] md:mx-0" aria-hidden="true">
				<div class="ring-border/80 overflow-hidden rounded-2xl ring-2 ring-offset-2 ring-offset-page">
					<div class="aspect-[3/5] w-full">
						<img
							src={publicUrl(siteConfig.headshotSrc)}
							alt=""
							width="450"
							height="750"
							class="h-full w-full object-cover object-[center_22%]"
							loading="lazy"
							decoding="async"
						/>
					</div>
				</div>
			</div>
			<div>
				<h2
					id="contact-heading"
					class="font-semibold text-4xl tracking-tight text-ink md:text-5xl"
				>
					Contact
				</h2>
				<p class="mt-3 max-w-xl text-muted">
					For professional inquiries, use the details below.
				</p>
				<ul class="mt-6 space-y-3 text-ink/95">
					{
						siteConfig.email && (
							<li>
								<span class="font-semibold text-accent">Email:</span>{" "}
								<a
									class="underline decoration-accent/40 underline-offset-4 hover:text-accent"
									href={`mailto:${siteConfig.email}`}
								>
									{siteConfig.email}
								</a>
							</li>
						)
					}
					{
						siteConfig.phone && phoneHref && (
							<li>
								<span class="font-semibold text-accent">Phone:</span>{" "}
								<a
									class="underline decoration-accent/40 underline-offset-4 hover:text-accent"
									href={phoneHref}
								>
									{siteConfig.phone}
								</a>
								<span class="text-muted"> (cell)</span>
							</li>
						)
					}
					<li>
						<span class="font-semibold text-accent">GitHub:</span>{" "}
						<a
							class="underline decoration-accent/40 underline-offset-4 hover:text-accent"
							href={siteConfig.githubUrl}
							target="_blank"
							rel="noopener noreferrer"
						>
							{siteConfig.githubUrl.replace("https://", "")}
						</a>
					</li>
					{
						siteConfig.linkedinUrl && (
							<li>
								<span class="font-semibold text-accent">LinkedIn:</span>{" "}
								<a
									class="underline decoration-accent/40 underline-offset-4 hover:text-accent"
									href={siteConfig.linkedinUrl}
									target="_blank"
									rel="noopener noreferrer"
								>
									Profile
								</a>
							</li>
						)
					}
				</ul>
			</div>
		</div>
	</div>
</section>
